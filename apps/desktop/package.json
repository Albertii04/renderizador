{
  "name": "@renderizador/desktop",
  "version": "0.3.2",
  "private": true,
  "main": "dist-electron/src/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "start:native": "electron .",
    "build": "tsc -p tsconfig.node.json && vite build",
    "pack:win": "pnpm build && electron-builder --win --publish never",
    "pack:mac": "pnpm build && electron-builder --mac --publish never",
    "pack:linux": "pnpm build && electron-builder --linux --publish never",
    "release:publish": "node scripts/publish-release.mjs",
    "release:win": "pnpm pack:win && pnpm release:publish",
    "release:mac": "pnpm pack:mac && pnpm release:publish",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit -p tsconfig.app.json && tsc --noEmit -p tsconfig.node.json"
  },
  "dependencies": {
    "@renderizador/supabase": "workspace:*",
    "@renderizador/types": "workspace:*",
    "@renderizador/ui": "workspace:*",
    "@renderizador/utils": "workspace:*",
    "@supabase/supabase-js": "^2.49.8",
    "@tanstack/react-query": "^5.75.7",
    "electron-log": "^5.4.0",
    "electron-updater": "^6.3.9",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "zustand": "^5.0.4"
  },
  "devDependencies": {
    "@renderizador/eslint-config": "workspace:*",
    "@renderizador/typescript-config": "workspace:*",
    "@tailwindcss/postcss": "^4.1.4",
    "@types/react": "~19.0.10",
    "@types/react-dom": "~19.0.4",
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.4.21",
    "electron": "^35.2.0",
    "electron-builder": "^25.1.8",
    "eslint": "^9.25.1",
    "postcss": "^8.5.3",
    "tailwindcss": "^4.1.4",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6"
  }
}
